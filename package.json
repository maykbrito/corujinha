{
  "name": "corujinha",
  "version": "1.1.0",
  "description": "AI companion that lives in a corner of your screen, sees what you're doing and helps — local and private",
  "main": "out/main/index.js",
  "license": "MIT",
  "author": "maykbrito",
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "predist": "npm run build",
    "dist": "electron-builder --mac",
    "test": "ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run --pool=forks --passWithNoTests",
    "test:watch": "ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs --pool=forks",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "lucide": "^1.25.0"
  }
}
